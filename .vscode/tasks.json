{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Zandronum",
            "type": "shell",
            "command": "${workspaceFolder}/mac_compile.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Zandronum (with sound)",
            "type": "shell",
            "command": "${workspaceFolder}/mac_compile.sh",
            "options": {
                "env": {
                    "SOUND": "1"
                }
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/build && ${workspaceFolder}/mac_compile.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
