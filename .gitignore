# here to keep src/zandronum clean).
src/zandronum/src/gitinfo.h
src/zandronum/src/network/servercommands.cpp
src/zandronum/src/network/servercommands.h
src/zandronum/sqlite/sqlite3.c
src/zandronum/sqlite/sqlite3.h
src/zandronum/sqlite/sqlite3ext.h
src/zandronum/sqlite/sqlite-*.tar.gz
**/__pycache__/

# Temporary files
*.tmp
*.log

# macOS
.DS_Store
build-oal/
build-mac-arm/
build-mac-x86/
build-mac/

# Harness-created git worktrees (.claude/skills is tracked, so ignore just this)
.claude/worktrees/
