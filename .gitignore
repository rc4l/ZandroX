# Build artifacts (fetched/built by mac_compile.sh)
deps/
build/

# Test/coverage build trees (cmake -S tests -B build-*)
build-tests/
build-san/
build-coverage/
build-cov-llvm/
build-cov*/

# Linux build outputs (Docker: Dockerfile.linux-build)
build-linux/
build-linux-zandronum
dist-linux/

# Windows build outputs (windows_compile.ps1 / windows_build.ps1)
build-win/
dist-windows/
dxsdk/
ZandroX-*-windows-x64.zip

# Files the engine build generates into the vendored source tree (upstream
# .hgignore treats these as generated; we vendored without .hg so ignore them
# here to keep src/zandronum clean).
src/zandronum/src/gitinfo.h
src/zandronum/src/network/servercommands.cpp
src/zandronum/src/network/servercommands.h
src/zandronum/sqlite/sqlite3.c
src/zandronum/sqlite/sqlite3.h
src/zandronum/sqlite/sqlite3ext.h
src/zandronum/sqlite/sqlite-*.tar.gz
**/__pycache__/

# Temporary files
*.tmp
*.log

# macOS
.DS_Store
build-oal/
build-mac-arm/
build-mac-x86/
build-mac/

# Harness-created git worktrees (.claude/skills is tracked, so ignore just this)
.claude/worktrees/

# llvm coverage raw profiles
*.profraw

# patch artifacts
*.rej
*.rej.orig
*.orig
