# [rc4l] clang-tidy runs only over our own code, never the legacy vendored engine tree.
# [rc4l] Checks are report-first for now (WarningsAsErrors empty) and can be tightened to errors as the new-code surface grows.
Checks: >
  bugprone-*,
  cppcoreguidelines-*,
  performance-*,
  portability-*,
  modernize-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-identifier-length,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay

# [rc4l] Colocated tests live in the same dirs as vendored engine headers, so no path
# prefix separates ours from upstream's. Diagnose only the test .cpp files passed on the
# command line, never their included (vendored) headers. '$^' matches nothing.
HeaderFilterRegex: '$^'

WarningsAsErrors: ''

FormatStyle: none
